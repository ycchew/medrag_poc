# for /f "tokens=*" %i in (.env) do set %i
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=clinic_password
POSTGRES_DB=clinic_db
DATABASE_HOST=localhost
DATABASE_PORT=5432

# LLM API Configuration
LLM_MODEL=qwen3.5-plus
LLM_API_URL=https://coding-intl.dashscope.aliyuncs.com

# Your DashScope API Key (required)
LLM_API_KEY=your_api_key_here

# Database URL (used by backend container)
DATABASE_URL=postgresql://clinic_user:clinic_password@localhost:5432/clinic_db
